{
  "name": "done-done",
  "description": "A sleek and simple todo list app",
  "version": "1.0.0",
  "author": "Jitendra Nirnejak <jeetnirnejak@gmail.com>",
  "type": "module",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "biome check .",
    "lint:fix": "biome check --fix .",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "type-check": "tsc --pretty --noEmit",
    "prepare": "husky",
    "test": "vitest",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:push": "drizzle-kit push",
    "db:studio": "drizzle-kit studio"
  },
  "dependencies": {
    "@neondatabase/serverless": "^1.0.2",
    "akar-icons": "^1.9.31",
    "bcryptjs": "^3.0.3",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "jsonwebtoken": "^9.0.3",
    "motion": "^12.29.2",
    "next": "^16.1.6",
    "next-view-transitions": "^0.3.5",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "sharp": "^0.34.5",
    "sonner": "^2.0.7",
    "use-sound": "^5.0.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.2",
    "@types/bcryptjs": "^3.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^25.1.0",
    "@types/react": "^19.2.10",
    "@vitejs/plugin-react": "^5.1.2",
    "babel-plugin-react-compiler": "^1.0.0",
    "drizzle-kit": "^0.31.8",
    "@biomejs/biome": "2.4.5",
    "happy-dom": "^20.4.0",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "postcss": "^8.5.6",
    "tailwindcss": "^4.1.18",
    "typescript": "^5.9.3",
    "vite-tsconfig-paths": "^6.0.5",
    "vitest": "^4.0.18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,json,css}": "biome check --fix --no-errors-on-unmatched"
  },
  "volta": {
    "node": "24.12.0"
  },
  "keywords": [
    "nextjs",
    "react",
    "typescript",
    "biome",
    "precommit"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/nirnejak/done-done"
  },
  "bugs": {
    "url": "https://github.com/nirnejak/done-done/issues"
  }
}
